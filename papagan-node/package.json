{
  "name": "papagan",
  "version": "0.1.4",
  "description": "Fast language detection for Node.js powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "language",
    "detection",
    "nlp",
    "ngram",
    "rust",
    "native",
    "napi"
  ],
  "homepage": "https://github.com/suleymanozkeskin/papagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/suleymanozkeskin/papagan.git"
  },
  "bugs": {
    "url": "https://github.com/suleymanozkeskin/papagan/issues"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "*.node"
  ],
  "napi": {
    "binaryName": "papagan",
    "packageName": "papagan",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build",
    "build:platform": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
