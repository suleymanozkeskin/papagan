{
  "name": "papagan",
  "version": "0.1.7",
  "description": "Fast language detection for Node.js powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "language",
    "detection",
    "nlp",
    "ngram",
    "rust",
    "native",
    "napi"
  ],
  "homepage": "https://github.com/suleymanozkeskin/papagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/suleymanozkeskin/papagan.git"
  },
  "bugs": {
    "url": "https://github.com/suleymanozkeskin/papagan/issues"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "*.node"
  ],
  "napi": {
    "binaryName": "papagan",
    "packageName": "papagan",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "optionalDependencies": {
    "papagan-darwin-x64": "0.1.7",
    "papagan-darwin-arm64": "0.1.7",
    "papagan-linux-x64-gnu": "0.1.7",
    "papagan-linux-arm64-gnu": "0.1.7",
    "papagan-linux-x64-musl": "0.1.7",
    "papagan-linux-arm64-musl": "0.1.7",
    "papagan-win32-x64-msvc": "0.1.7"
  },
  "scripts": {
    "build": "napi build --release --dts native.generated.d.ts",
    "build:platform": "napi build --release --platform --dts native.generated.d.ts --no-js",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}